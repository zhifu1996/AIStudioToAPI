# ===================================
# Server Configuration
# ===================================

# HTTP server port
PORT=7860

# Server listening host address (use 0.0.0.0 for all interfaces)
HOST=0.0.0.0

# WebSocket server port for internal browser communication
# ⚠️ DEPRECATED: This environment variable is no longer supported in the current version
# The WebSocket port is now fixed at 9998 and cannot be customized
# WS_PORT=9998

# ===================================
# Authentication Configuration
# ===================================

# Web console username (optional)
# If both username and password are set, both are required to login.
WEB_CONSOLE_USERNAME=

# Web console password (optional)
# If only password is set, the login page will only ask for the password.
# If neither is set, the system falls back to API_KEYS for console login.
WEB_CONSOLE_PASSWORD=

# API keys for authenticating client requests (comma-separated)
# Example: your-api-key-1,your-api-key-2
# If not set, default key "123456" will be used
API_KEYS=

# ===================================
# Security Configuration
# ===================================

# Enable secure cookies (HTTPS only)
# Set to 'true' when using HTTPS, 'false' for HTTP
# Default: false (allows HTTP for easier setup)
SECURE_COOKIES=false

# Login rate limiting configuration
# Maximum failed login attempts allowed within the time window
# Set to 0 to disable rate limiting (not recommended for production)
# Default: 5
RATE_LIMIT_MAX_ATTEMPTS=5

# Time window for rate limiting in minutes
# Failed login attempts are counted within this time window
# Default: 15 (minutes)
RATE_LIMIT_WINDOW_MINUTES=15

# Initial authentication index to use on startup
INITIAL_AUTH_INDEX=0

# ===================================
# UI Configuration
# ===================================

# Custom favicon URL for the web interface
# Supports any image format (ICO, PNG, SVG, etc.) and any size
# Common sizes: 16x16, 32x32, 48x48 (ICO/PNG) or vector (SVG)
# Default: /AIStudio_logo.svg (local SVG icon)
# Example: https://example.com/favicon.ico
# If not set, the default local icon will be used
ICON_URL=

# Enable version update check on page load
# When enabled, the UI will check GitHub for new versions
# Default: true
CHECK_UPDATE=true

# ===================================
# Logging Configuration
# ===================================

# Server log level
# Supported values: INFO, DEBUG
# Default: INFO
LOG_LEVEL=INFO

# Timezone used for logs and displayed times
# Example: Asia/Shanghai, America/New_York, Europe/London
# If not set, defaults to the system timezone
TZ=

# ===================================
# Browser Configuration
# ===================================

# Path to the Camoufox browser executable
# Leave empty to use the default path based on your OS
CAMOUFOX_EXECUTABLE_PATH=

# Maximum number of accounts that can be logged in simultaneously
# Accounts logged in simultaneously can switch faster without re-login
# Higher values consume more memory (approx: 1 account ~700MB, 2 accounts ~950MB, 3 accounts ~1100MB)
# Set to 0 for unlimited
# Default: 1
MAX_CONTEXTS=1

# ===================================
# Request Handling Configuration
# ===================================

# Streaming mode: "fake" (buffer then stream) or "real" (true streaming)
STREAMING_MODE=real

# Maximum number of retries for failed requests
MAX_RETRIES=3

# Delay between retries in milliseconds
RETRY_DELAY=2000

# Force enable thinking mode for all requests
# When enabled, all requests will use thinking mode regardless of client settings
# Default: false
FORCE_THINKING=false

# Force enable web search for all requests
# When enabled, all requests will include web search capability
# Default: false
FORCE_WEB_SEARCH=false

# Force enable URL context for all requests
# When enabled, all requests will include URL context capability
# Default: false
FORCE_URL_CONTEXT=false

# Enable automatic auth credential updates
# When enabled, auth files are refreshed after successful login/account switch
# and periodically every 24 hours
# Default: true
ENABLE_AUTH_UPDATE=true

# Enable request usage statistics
# When disabled, the service will not load local stats, will not write stats,
# and /api/usage-stats will return an empty payload
# Default: true
ENABLE_USAGE_STATS=true

# ===================================
# Account Switching Configuration
# ===================================

# Number of requests before automatically switching accounts
# Set to 0 to disable usage-based switching
SWITCH_ON_USES=40

# Number of consecutive failures before switching accounts
# Set to 0 to disable failure-based switching
FAILURE_THRESHOLD=3

# HTTP status codes that trigger immediate account switching (comma-separated)
# Common values: 429 (Too Many Requests), 503 (Service Unavailable)
# Leave empty to disable this feature
IMMEDIATE_SWITCH_STATUS_CODES=429,503

# ===================================
# Proxy Configuration
# ===================================

# HTTP proxy for outgoing requests (optional)
# Used when your server needs a proxy to access Google services
# Example: http://127.0.0.1:7890
HTTP_PROXY=

# HTTPS proxy for outgoing requests (optional)
# Usually set to the same value as HTTP_PROXY
HTTPS_PROXY=

# Addresses that should bypass the proxy (optional, comma-separated)
# The project automatically bypasses local addresses (localhost, 127.0.0.1, 0.0.0.0).
# Use this only if you need to bypass additional specific domains or IP ranges.
# Example: .example.com,192.168.1.0/24
NO_PROXY=
